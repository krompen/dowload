# --- ПРОСМОТР КОНТЕНТА ---
@dp.message(F.text.in_({"🎬 Видео (2 💎)", "🖼 Фото (1 💎)"}))
async def view(message: types.Message):
    c_type = "video" if "Видео" in message.text else "photo"
    cost = 2 if c_type == "video" else 1
    
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT balance FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
            bal = (await c.fetchone())[0]
            if bal < cost: return await message.answer("⚠️ Недостаточно алмазиков!")
            
        async with db.execute("SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1", (c_type,)) as c:
            item = await c.fetchone()
            if not item: return await message.answer("Контента пока нет.")
            
            await db.execute("UPDATE users SET balance = balance - ? WHERE user_id = ?", (cost, message.from_user.id))
            await db.commit()
            if c_type == "video": await message.answer_video(item[0])
            else: await message.answer_photo(item[0])

# --- ПРЕДЛОЖКА ---
@dp.message(F.text == "💡 Предложить")
async def suggest_start(message: types.Message, state: FSMContext):
    await state.set_state(States.suggesting)
    await message.answer("Пришли фото или видео для предложки:")

@dp.message(States.suggesting)
async def suggest_proc(message: types.Message, state: FSMContext):
    if not (message.photo or message.video):
        return await message.answer("Скинь медиафайл!")
    
    btn = InlineKeyboardBuilder()
    btn.button(text="✅ Принять", callback_data=f"app_{message.from_user.id}")
    btn.button(text="❌ Отклонить", callback_data="rej")
    
    await bot.send_message(ADMIN_ID, f"💡 Предложка от {message.from_user.id}:")
    if message.photo: await bot.send_photo(ADMIN_ID, message.photo[-1].file_id, reply_markup=btn.as_markup())
    else: await bot.send_video(ADMIN_ID, message.video.file_id, reply_markup=btn.as_markup())
    
    await state.clear()
    await message.answer("🚀 Отправлено на модерацию!")

@dp.callback_query(F.data.startswith("app_"))
async def approve(call: types.CallbackQuery):
    uid = int(call.data.split("_")[1])
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute("UPDATE users SET balance = balance + 5 WHERE user_id = ?", (uid,))
        await db.commit()
    await bot.send_message(uid, "🎉 Ваше предложение принято! +5 💎")
    await call.message.edit_caption(caption="✅ Одобрено")

