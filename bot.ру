@dp.message(CommandStart())
async def start(message: types.Message):
    args = message.text.split()
    ref_id = int(args[1]) if len(args) > 1 and args[1].isdigit() else None
    
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT user_id FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
            if not await c.fetchone():
                await db.execute("INSERT INTO users (user_id, referrer_id) VALUES (?, ?)", (message.from_user.id, ref_id))
                if ref_id:
                    await db.execute("UPDATE users SET balance = balance + 3 WHERE user_id = ?", (ref_id,))
                    try: await bot.send_message(ref_id, "🤝 По вашей ссылке зашел новый юзер! +3 💎")
                    except: pass
                await db.commit()
    await message.answer("👋 Добро пожаловать!", reply_markup=main_menu(message.from_user.id))

@dp.message(F.text == "👤 Профиль")
async def profile(message: types.Message):
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT balance, premium_until FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
            res = await c.fetchone()
            bal, prem = res[0], res[1]
            is_prem = prem and datetime.fromisoformat(prem) > datetime.now()
            status = f"🌟 Премиум до {prem}" if is_prem else "Обычный"
            await message.answer(f"👤 **Профиль**\n\n💰 Баланс: {bal} 💎\n👑 Статус: {status}", parse_mode="Markdown")

@dp.message(F.text == "🎁 Бонус")
async def daily_bonus(message: types.Message):
    today = str(date.today())
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT last_bonus, premium_until FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
            res = await c.fetchone()
            if res[0] == today:
                return await message.answer("❌ Бонус уже получен! Приходи завтра.")
            
            is_prem = res[1] and datetime.fromisoformat(res[1]) > datetime.now()
            reward = 15 if is_prem else 5
            await db.execute("UPDATE users SET balance = balance + ?, last_bonus = ? WHERE user_id = ?", (reward, today, message.from_user.id))
            await db.commit()
            await message.answer(f"✅ Получено {reward} 💎!")

