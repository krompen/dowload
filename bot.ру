@dp.callback_query(F.data == "adm_upload")
async def adm_upload(call: types.CallbackQuery, state: FSMContext):
    await state.set_state(Form.uploading)
    await call.message.answer("📥 **Режим загрузки**\nПрисылай медиа. Для выхода напиши /stop", parse_mode="Markdown")
    await call.answer()

@dp.message(Form.uploading)
async def process_upload(message: types.Message, state: FSMContext):
    if message.text == "/stop":
        await state.clear()
        return await message.answer("✅ Загрузка окончена", reply_markup=main_kb(ADMIN_ID))
    
    if message.photo:
        await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("photo", message.photo[-1].file_id))
    elif message.video:
        await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("video", message.video.file_id))
    await db.commit()
    await message.answer("➕ Добавлено")

# --- ВЫДАЧА ПРЕМИУМА ЧЕРЕЗ КНОПКУ ---
@dp.callback_query(F.data == "adm_give_prem")
async def adm_give_prem(call: types.CallbackQuery, state: FSMContext):
    await state.set_state(Form.giving_prem)
    await call.message.answer("👑 **Выдача Премиума**\n\nВведите данные по шаблону:\n`ID ДНИ` (например: `1234567 30`)", parse_mode="Markdown")
    await call.answer()

@dp.message(Form.giving_prem)
async def process_give_prem(message: types.Message, state: FSMContext):
    try:
        uid, days = message.text.split()
        date_limit = (datetime.now() + timedelta(days=int(days))).isoformat()
        await db.execute("UPDATE users SET premium_until = ? WHERE user_id = ?", (date_limit, uid))
        await db.commit()
        await message.answer(f"✅ Премиум выдан пользователю {uid} на {days} дн.")
        await bot.send_message(uid, f"👑 Тебе выдан Премиум на {days} дней!")
    except:
        await message.answer("❌ Ошибка. Шаблон: `ID ДНИ`")
    await state.clear()

