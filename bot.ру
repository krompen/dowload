# --- БАЗА ДАННЫХ ---
async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute('''CREATE TABLE IF NOT EXISTS users 
            (user_id INTEGER PRIMARY KEY, balance INTEGER DEFAULT 5, 
            premium_until TEXT, last_bonus TEXT, referrer_id INTEGER)''')
        await db.execute('''CREATE TABLE IF NOT EXISTS content 
            (id INTEGER PRIMARY KEY AUTOINCREMENT, type TEXT, file_id TEXT)''')
        await db.execute('''CREATE TABLE IF NOT EXISTS promos 
            (code TEXT PRIMARY KEY, reward INTEGER, uses INTEGER)''')
        await db.commit()

