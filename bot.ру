@dp.message(F.text == "👤 Профиль")
async def profile(message: types.Message):
    async with db.execute("SELECT balance, premium_until FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        bal, prem = await c.fetchone()
        is_prem = prem and datetime.fromisoformat(prem) > datetime.now()
        status = f"🌟 Премиум до {prem[:10]}" if is_prem else "Обычный"
        await message.answer(f"👤 **Твой профиль**\n\n💰 Баланс: `{bal}` 💎\n👑 Статус: {status}", parse_mode="Markdown")

# --- КОНТЕНТ ---
@dp.message(F.text.in_({"🎬 Видео (2 💎)", "🖼 Фото (1 💎)"}))
async def get_content(message: types.Message):
    c_type = "video" if "Видео" in message.text else "photo"
    cost = 2 if c_type == "video" else 1
    
    async with db.execute("SELECT balance FROM users WHERE user_id = ?", (message.from_user.id,)) as c:
        bal = (await c.fetchone())[0]
        if bal < cost: return await message.answer("❌ Недостаточно 💎")

    async with db.execute("SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1", (c_type,)) as c:
        res = await c.fetchone()
        if not res: return await message.answer("Контент скоро будет!")
        
        await db.execute("UPDATE users SET balance = balance - ? WHERE user_id = ?", (cost, message.from_user.id))
        await db.commit()
        if c_type == "video": await message.answer_video(res[0])
        else: await message.answer_photo(res[0])

