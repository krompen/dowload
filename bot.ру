@dp.message(F.text == "📥 Загрузить", F.from_user.id == ADMIN_ID)
async def upload_mode(message: types.Message, state: FSMContext):
    await state.set_state(States.uploading)
    await message.answer("Режим загрузки! Шли файлы. Когда всё — жми /done", reply_markup=types.ReplyKeyboardRemove())

@dp.message(States.uploading)
async def mass_upload(message: types.Message, state: FSMContext):
    if message.text == "/done":
        await state.clear()
        return await admin_main(message)
    
    async with aiosqlite.connect(DB_PATH) as db:
        if message.photo:
            await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("photo", message.photo[-1].file_id))
            await message.answer("📸 +1 фото")
        elif message.video:
            await db.execute("INSERT INTO content (type, file_id) VALUES (?, ?)", ("video", message.video.file_id))
            await message.answer("🎥 +1 видео")
        await db.commit()

