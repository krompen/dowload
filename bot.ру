@dp.message(F.text == "🎫 Промокод")
async def promo_start(message: types.Message, state: FSMContext):
    await state.set_state(States.promo_activate)
    await message.answer("Введите промокод:")

@dp.message(States.promo_activate)
async def promo_act(message: types.Message, state: FSMContext):
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT reward, uses FROM promos WHERE code = ?", (message.text,)) as c:
            row = await c.fetchone()
            if row and row[1] > 0:
                await db.execute("UPDATE users SET balance = balance + ? WHERE user_id = ?", (row[0], message.from_user.id))
                await db.execute("UPDATE promos SET uses = uses - 1 WHERE code = ?", (message.text,))
                await db.commit()
                await message.answer(f"✅ Активировано! +{row[0]} 💎")
            else:
                await message.answer("❌ Неверный код или лимит исчерпан.")
    await state.clear()

# --- КОМАНДЫ ДЛЯ ПРЕМИУМА ---
@dp.message(Command("setprem"), F.from_user.id == ADMIN_ID)
async def set_prem(message: types.Message):
    # Формат: /setprem 12345678 30 (ID и кол-во дней)
    p = message.text.split()
    if len(p) == 3:
        date_limit = (datetime.now() + timedelta(days=int(p[2]))).isoformat()
        async with aiosqlite.connect(DB_PATH) as db:
            await db.execute("UPDATE users SET premium_until = ? WHERE user_id = ?", (date_limit, p[1]))
            await db.commit()
        await message.answer("✅ Премиум выдан!")
        await bot.send_message(p[1], f"👑 Вам выдан Премиум на {p[2]} дней!")

